generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Tenant {
  id        String   @id @default(cuid())
  nombre    String
  slug      String   @unique
  logo      String?
  activo    Boolean  @default(true)
  createdAt DateTime @default(now())

  usuarios UserTenant[]
  eventos  Evento[]

  @@map("tenants")
}

model UserTenant {
  id       String @id @default(cuid())
  userId   String
  tenantId String
  role     String @default("USER")

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([userId, tenantId])
  @@map("user_tenants")
}

// Role: ADMIN | USER | CONTABILIDAD
model User {
  id           String   @id @default(cuid())
  email        String   @unique
  name         String?
  image        String?
  telefono     String?
  role         String   @default("USER")
  isSuperAdmin Boolean  @default(false)
  createdAt    DateTime @default(now())

  tenants                  UserTenant[]
  solicitudes              Solicitud[]
  solicitudesAprobadas     Solicitud[]   @relation("SolicitudAprobador")
  facturas                 Factura[]
  lineasAsignadas          PresupuestoLinea[]
  cotizaciones             Cotizacion[]
  cotizacionesAprobadas    Cotizacion[]  @relation("CotizacionAprobador")
  cajasMenuda              CajaMenuda[]
  cajasMenudaAprobadas     CajaMenuda[]  @relation("CajaMenudaAprobador")
  cajasMenudaPagadas       CajaMenuda[]  @relation("CajaMenudaPagador")

  @@map("users")
}

// TipoTarifa: DIARIA | QUINCENAL | MENSUAL
model Tarifa {
  id           String   @id @default(cuid())
  tipo         String   @unique
  precioPorDia Float
  updatedAt    DateTime @updatedAt

  solicitudes Solicitud[]

  @@map("tarifas")
}

model Venue {
  id        String   @id @default(cuid())
  nombre    String   @unique
  direccion String?
  activo    Boolean  @default(true)
  createdAt DateTime @default(now())

  eventos Evento[]

  @@map("venues")
}

// TipoEvento: PROPIO | CONTRATADO | COPRODUCCION
// EstadoEvento: ACTIVO | COMPLETADO | CANCELADO
model Evento {
  id               String   @id @default(cuid())
  nombre           String
  descripcion      String?
  fechaInicio      DateTime
  fechaFin         DateTime
  estado           String   @default("ACTIVO")
  tipoEvento       String?  // PROPIO | CONTRATADO | COPRODUCCION
  venueId          String?
  tenantId         String?
  tieneSocio       Boolean  @default(false)
  nombreSocio      String?
  createdAt        DateTime @default(now())

  solicitudes  Solicitud[]
  asignaciones AsignacionAplicante[]
  facturas     Factura[]
  cajasMenuda  CajaMenuda[]
  venue        Venue?        @relation(fields: [venueId], references: [id])
  tenant       Tenant?       @relation(fields: [tenantId], references: [id])
  presupuesto  Presupuesto?

  @@map("eventos")
}

model Presupuesto {
  id              String   @id @default(cuid())
  eventoId        String   @unique
  artista         String?
  pais            String?
  ciudad          String?
  promotor        String?
  moneda          String   @default("USD")
  exchangeRate    Float    @default(1)
  numShows        Int      @default(1)
  artistGuarantee  Float    @default(0)
  artistBackend    Boolean  @default(false)
  artistBackendPct Float    @default(80)
  updatedAt        DateTime @updatedAt
  createdAt        DateTime @default(now())

  evento              Evento                @relation(fields: [eventoId], references: [id])
  categorias          PresupuestoCategoria[]
  ticketZonas         TicketZona[]
  patrocinios         Patrocinio[]
  boletosVendidosReal BoletosVendidosReal[]
  socios              SocioPresupuesto[]

  @@map("presupuestos")
}

model SocioPresupuesto {
  id            String @id @default(cuid())
  presupuestoId String
  nombre        String
  porcentaje    Float  @default(0)
  orden         Int    @default(0)

  presupuesto Presupuesto @relation(fields: [presupuestoId], references: [id], onDelete: Cascade)

  @@map("socios_presupuesto")
}

model PresupuestoCategoria {
  id             String   @id @default(cuid())
  presupuestoId  String
  nombre         String
  orden          Int      @default(0)
  createdAt      DateTime @default(now())

  presupuesto Presupuesto        @relation(fields: [presupuestoId], references: [id], onDelete: Cascade)
  lineas      PresupuestoLinea[]

  @@map("presupuesto_categorias")
}

model PresupuestoLinea {
  id             String   @id @default(cuid())
  categoriaId    String
  descripcion    String
  nota           String?
  montoLocal     Float    @default(0)
  montoUsd       Float    @default(0)
  orden          Int      @default(0)
  confianza      String?  // HIGH | LOW
  asignadoAId    String?  // userId responsable de cargar cotizaciones

  categoria   PresupuestoCategoria @relation(fields: [categoriaId], references: [id], onDelete: Cascade)
  asignadoA   User?                @relation(fields: [asignadoAId], references: [id])
  cotizaciones Cotizacion[]

  @@map("presupuesto_lineas")
}

// Estado: PENDIENTE | APROBADA | RECHAZADA
model Cotizacion {
  id          String   @id @default(cuid())
  lineaId     String
  creadoPorId String
  concepto    String?  // Agrupa cotizaciones del mismo sub-rubro (ej: "Comida", "Bebidas")
  descripcion String?
  estado      String   @default("PENDIENTE")
  notaAdmin   String?
  montoTotal  Float    @default(0)
  // Archivo adjunto de la cotización (PDF/imagen)
  archivoUrl  String?
  archivoNombreCot String?
  // Factura real subida después de aprobación
  facturaUrl        String?
  facturaNumero     String?
  facturaProveedor  String?
  facturaFechaEmision String?
  facturaFechaPago  String?
  facturaSubtotal   Float?
  facturaItbms      Float?
  facturaTotal      Float?
  facturaSubida     Boolean  @default(false)
  aprobadaPorId     String?
  aprobadaEn        DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  linea       PresupuestoLinea   @relation(fields: [lineaId], references: [id], onDelete: Cascade)
  creadoPor   User               @relation(fields: [creadoPorId], references: [id])
  aprobadaPor User?              @relation("CotizacionAprobador", fields: [aprobadaPorId], references: [id])
  facturas    CotizacionFactura[]

  @@map("cotizaciones")
}

model CotizacionFactura {
  id           String @id @default(cuid())
  cotizacionId String
  descripcion  String
  proveedor    String?
  monto        Float  @default(0)
  archivoNombre String?

  cotizacion Cotizacion @relation(fields: [cotizacionId], references: [id], onDelete: Cascade)

  @@map("cotizacion_facturas")
}

model BoletosVendidosReal {
  id            String @id @default(cuid())
  presupuestoId String
  zona          String
  vendidos      Int    @default(0)
  precio        Float  @default(0)
  orden         Int    @default(0)

  presupuesto Presupuesto @relation(fields: [presupuestoId], references: [id], onDelete: Cascade)

  @@map("boletos_vendidos_real")
}

model TicketZona {
  id             String   @id @default(cuid())
  presupuestoId  String
  scaling        String?
  zona           String
  capacity       Int      @default(0)
  killsBlocks    Int      @default(0)
  comps          Int      @default(0)
  ticketPriceLocal Float  @default(0)
  ticketPriceUsd   Float  @default(0)
  orden          Int      @default(0)

  presupuesto Presupuesto @relation(fields: [presupuestoId], references: [id], onDelete: Cascade)

  @@map("ticket_zonas")
}

model Patrocinador {
  id        String   @id @default(cuid())
  nombre    String   @unique
  categoria String?  // ALCOHOL | BANCO | COMIDA_RAPIDA | AEROLINEA | HOTEL | MODA | RENTAL_CAR
  activo    Boolean  @default(true)
  createdAt DateTime @default(now())

  patrocinios Patrocinio[]

  @@map("patrocinadores")
}

model Patrocinio {
  id              String   @id @default(cuid())
  presupuestoId   String
  patrocinadorId  String?
  nombre          String
  tipo            String?  // ACTIVACION | BTL | BRANDING
  tipoPago        String?  // CANJE | EFECTIVO
  montoLocal      Float    @default(0)
  montoUsd        Float    @default(0)
  notas           String?
  boletos         Json?    // [{zona, cantidad, precioUsd}] — informativo, no afecta ganancia
  esReal          Boolean  @default(false) // false=presupuestado, true=real cobrado

  presupuesto  Presupuesto   @relation(fields: [presupuestoId], references: [id], onDelete: Cascade)
  patrocinador Patrocinador? @relation(fields: [patrocinadorId], references: [id])

  @@map("patrocinios")
}

// EstadoSolicitud: PENDIENTE | APROBADA | RECHAZADA
model Solicitud {
  id            String   @id @default(cuid())
  eventoId      String
  solicitanteId String
  tarifaId      String?
  numPersonas   Int
  funcion       String
  estado        String   @default("PENDIENTE")
  fechaInicioLabor DateTime?
  fechaFinLabor    DateTime?
  presupuesto   Float?
  costoTotal    Float?
  comentario    String?
  notaAdmin     String?
  aprobadoPorId String?
  aprobadoEn    DateTime?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  evento      Evento    @relation(fields: [eventoId], references: [id])
  solicitante User      @relation(fields: [solicitanteId], references: [id])
  tarifa      Tarifa?   @relation(fields: [tarifaId], references: [id])
  aprobadoPor User?     @relation("SolicitudAprobador", fields: [aprobadoPorId], references: [id])

  asignaciones AsignacionAplicante[]

  @@map("solicitudes")
}

model Factura {
  id            String   @id @default(cuid())
  eventoId      String?
  creadoPorId   String
  responsable   String
  numeroFactura String?
  proveedor     String?
  rucDv         String?
  descripcion   String?
  fechaEmision  String?
  fechaPago     String?
  subtotal      Float    @default(0)
  itbms         Float    @default(0)
  total         Float    @default(0)
  archivoNombre String?
  tipoPago      String?  // CAJA_MENUDA | REEMBOLSO
  createdAt     DateTime @default(now())

  evento    Evento? @relation(fields: [eventoId], references: [id])
  creadoPor User    @relation(fields: [creadoPorId], references: [id])

  @@map("facturas")
}

model Puesto {
  id        String   @id @default(cuid())
  nombre    String   @unique
  activo    Boolean  @default(true)
  createdAt DateTime @default(now())

  @@map("puestos")
}

model Aplicante {
  id                  String    @id @default(cuid())
  nombreCompleto      String
  cedula              String    @unique
  telefono            String
  email               String    @unique
  cuentaBancaria      String
  banco               String?
  tipoCuenta          String?
  terminosAceptados   Boolean   @default(false)
  terminosAceptadosAt DateTime?
  qrSecret            String    @default(cuid())
  activo              Boolean   @default(true)
  passwordHash        String?
  noApto              Boolean   @default(false)
  motivoNoApto        String?
  fotoPersonal        String?
  fotoCedula          String?
  fotoConCedula       String?
  createdAt           DateTime  @default(now())

  asignaciones AsignacionAplicante[]

  @@map("aplicantes")
}

// EstadoAsignacion: ACTIVA | COMPLETADA | CANCELADA
model AsignacionAplicante {
  id          String   @id @default(cuid())
  aplicanteId String
  eventoId    String
  solicitudId String
  funcion     String
  estado      String   @default("ACTIVA")
  createdAt   DateTime @default(now())

  aplicante Aplicante @relation(fields: [aplicanteId], references: [id])
  evento    Evento    @relation(fields: [eventoId], references: [id])
  solicitud Solicitud @relation(fields: [solicitudId], references: [id])
  registros RegistroAsistencia[]

  @@unique([aplicanteId, eventoId])
  @@map("asignaciones_aplicantes")
}

// TipoRegistro: ENTRADA | SALIDA
model RegistroAsistencia {
  id           String   @id @default(cuid())
  asignacionId String
  tipo         String
  timestamp    DateTime @default(now())
  tokenUsado   String

  asignacion AsignacionAplicante @relation(fields: [asignacionId], references: [id])

  @@unique([asignacionId, tipo, tokenUsado])
  @@map("registros_asistencia")
}

// Estado: PENDIENTE | APROBADA | RECHAZADA | RESPALDOS_ENTREGADOS | PAGADA
model CajaMenuda {
  id               String    @id @default(cuid())
  eventoId         String
  solicitanteId    String
  descripcion      String
  montoSolicitado  Float
  montoAprobado    Float?
  estado           String    @default("PENDIENTE")
  notaAdmin        String?
  aprobadoPorId    String?
  aprobadoEn       DateTime?
  pagadoPorId      String?
  pagadoEn         DateTime?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  evento       Evento              @relation(fields: [eventoId], references: [id])
  solicitante  User                @relation(fields: [solicitanteId], references: [id])
  aprobadoPor  User?               @relation("CajaMenudaAprobador", fields: [aprobadoPorId], references: [id])
  pagadoPor    User?               @relation("CajaMenudaPagador",   fields: [pagadoPorId],   references: [id])
  facturas     FacturaCajaMenuda[]

  @@unique([solicitanteId, eventoId])
  @@map("cajas_menuda")
}

model FacturaCajaMenuda {
  id            String   @id @default(cuid())
  cajaMenudaId  String
  descripcion   String?
  proveedor     String?
  numeroFactura String?
  rucDv         String?
  fechaEmision  String?
  subtotal      Float    @default(0)
  itbms         Float    @default(0)
  total         Float    @default(0)
  archivoNombre String?
  archivoPath   String?
  createdAt     DateTime @default(now())

  cajaMenuda CajaMenuda @relation(fields: [cajaMenudaId], references: [id], onDelete: Cascade)

  @@map("facturas_caja_menuda")
}

