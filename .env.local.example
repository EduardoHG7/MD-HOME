# ============================================================
# MAGIC DREAMS STAFF - Variables de entorno
# Copiar este archivo como .env.local y completar los valores
# ============================================================

# NextAuth
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=genera-un-secreto-largo-aqui-con-openssl-rand-base64-32

# Microsoft Azure AD
# Crear App Registration en: https://portal.azure.com → Azure Active Directory → App registrations
AZURE_AD_CLIENT_ID=tu-client-id-de-azure
AZURE_AD_CLIENT_SECRET=tu-client-secret-de-azure
AZURE_AD_TENANT_ID=tu-tenant-id-de-azure

# Base de datos (SQLite para desarrollo)
DATABASE_URL="file:./dev.db"

# Para producción con Azure SQL:
# DATABASE_URL="sqlserver://SERVER:1433;database=DB_NAME;user=USER;password=PASSWORD;encrypt=true"

# Secreto para tokens QR (usa un valor largo y aleatorio)
QR_SECRET=magic-dreams-qr-secret-cambia-esto-en-produccion

# Email del primer administrador (debe coincidir con cuenta de Microsoft)
ADMIN_EMAIL=admin@tudominio.com
